library(dplyr)
library(tidyr)
library(scales)

# =========================================================
# 1. BASE
# =========================================================

dados <- srag %>%
  filter(
    !is.na(obito),
    !is.na(periodo),
    !is.na(regiao),
    !is.na(faixa_etaria),
    !is.na(sexo)
  )

# =========================================================
# 2. CFR BRUTA
# =========================================================

cfr_bruta <- dados %>%
  group_by(regiao, periodo) %>%
  summarise(
    obitos = sum(obito == 1),
    total = n(),
    cfr_bruta = obitos / total,
    .groups = "drop"
  )

# =========================================================
# 3. POPULAÇÃO PADRÃO (USAR SUA BASE OU DEFINIR)
# =========================================================

# distribuição da população padrão (ex: própria base agregada)
pop_padrao <- dados %>%
  count(faixa_etaria, sexo) %>%
  mutate(
    peso = n / sum(n)
  ) %>%
  select(faixa_etaria, sexo, peso)

# =========================================================
# 4. CFR POR ESTRATO
# =========================================================

cfr_estrato <- dados %>%
  group_by(regiao, periodo, faixa_etaria, sexo) %>%
  summarise(
    obitos = sum(obito == 1),
    total = n(),
    taxa = obitos / total,
    .groups = "drop"
  )

# =========================================================
# 5. PADRONIZAÇÃO DIRETA
# =========================================================

cfr_padronizada <- cfr_estrato %>%
  left_join(pop_padrao, by = c("faixa_etaria","sexo")) %>%
  mutate(
    taxa_ponderada = taxa * peso
  ) %>%
  group_by(regiao, periodo) %>%
  summarise(
    cfr_padronizada = sum(taxa_ponderada, na.rm = TRUE),
    .groups = "drop"
  )

# =========================================================
# 6. UNIR RESULTADOS
# =========================================================

tabela_cfr <- cfr_bruta %>%
  left_join(cfr_padronizada, by = c("regiao","periodo")) %>%
  
  mutate(
    CFR_crude = percent(cfr_bruta, accuracy = 0.1),
    CFR_adjusted = percent(cfr_padronizada, accuracy = 0.1)
  ) %>%
  
  select(
    Region = regiao,
    Period = periodo,
    `Crude CFR` = CFR_crude,
    `Adjusted CFR` = CFR_adjusted
  ) %>%
  
  arrange(Region, Period)

# =========================================================
# 7. VISUALIZAR
# =========================================================

tabela_cfr


