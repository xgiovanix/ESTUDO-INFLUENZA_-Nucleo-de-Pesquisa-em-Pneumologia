      PCR_RESUL, DS_PCR_OUT, 
      idade_anos, idade_cat, ano, ano_se_pri, regiao, covid_caso, covid_obito, 
      influenza_h1n1_caso, influenza_h1n1_obito, influenza_h3n2_caso, influenza_h3n2_obito, 
      influenza_A_n_subtipavel_caso, influenza_A_n_subtipavel_obito, influenza_A_n_sub_caso, 
      influenza_A_n_sub_obito, influenza_A_total, influenza_A_total_obito, 
      influenza_B_vict_caso, influenza_B_vict_obito, influenza_B_yam_caso, 
      influenza_B_yam_obito, influenza_B_inconclusivo_caso, influenza_B_inconclusivo_obito, 
      influenza_B_total, influenza_B_total_obito, influenza_geral_casos, influenza_geral_obito, 
