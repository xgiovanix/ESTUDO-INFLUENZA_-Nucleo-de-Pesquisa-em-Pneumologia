## Columns with same options, Yes, No, Ignored, NA

columns <- c("FEBRE", "TOSSE", "GARGANTA", "DISPNEIA", "DESC_RESP",
             "SATURACAO", "DIARREIA", "VOMITO", "OUTRO_SIN", "PUERPERA",
             "CARDIOPATI", "HEMATOLOGI", "SIND_DOWN", "HEPATICA", "ASMA",
             "DIABETES", "NEUROLOGIC", "PNEUMOPATI", "IMUNODEPRE",
             "RENAL", "OBESIDADE", "OUT_MORBI")


#========= ESTOU CODIFICANDO AS VARIAVEIS CONFORME O ESTUDO DE RANZANI==========
#EM CADA VARIaVEL SEGUE A DESCRIÇÃO ============================================

INFLUENZA_FULL <- INFLUENZA_FULL %>% # AQUI NO SCRIPR RANZANI USOU-SE SRAG TOTAL (srag_adults_pcr ), EM TODO NOSSO SCRIPT SERA INFLUNZA
  # CS_SEXO Recoded    to    2    levels.    The    Ignored    level    was    
  # considered    as    missing
  mutate(CS_SEXO = case_when(CS_SEXO == "M" ~ "Male",
                             CS_SEXO == "F" ~ "Female")) %>% 
  # FAIXA DE IDADE Recoded    to    6    levels- nova variavel que categoriza as idades com base na
  # idade_anos, previamente criada pelo SCRIPT do Ministerio da Saúde
  mutate(FAIXA_IDADE = case_when(idade_anos <= 39 ~ "18-39",
                                 idade_anos <= 49 ~ "40-49",
                                 idade_anos <= 59 ~ "50-59",
                                 idade_anos <= 69 ~ "60-69",
                                 idade_anos <= 79 ~ "70-79",
                                 TRUE ~ "80+")) %>%
  
  # CS_RACA, Recoded    to    4    levels: combined    Black    and    
  # Brown;    kept    White,    Asian    and    Indigenous.    The    
  # Ignored    level    was    considered    as    missing
  
  mutate(CS_RACA = case_when(CS_RACA == "1" ~ "White",
                             CS_RACA == "2" ~ "Black/Brown",
                             CS_RACA == "3" ~ "Asian",
                             CS_RACA == "4" ~ "Black/Brown",
                             CS_RACA == "5" ~ "Indigenous")) %>% 
  
  # CS_ESCOL_N Recoded    to    4    levels.        Collapsing    the    categories    
  # of    intermediate    levels    of    education    in    “Up    to # high    school”    (included    middle    and    elementary    
  #school).    The    Ignored    level    was    considered    as missing
  
  mutate(CS_ESCOL_N = case_when(CS_ESCOL_N == "0" ~ "Illiterate",   # Not applicable not present in this filtered adults dataset
                                CS_ESCOL_N == "1" ~ "Up to high school",
                                CS_ESCOL_N == "2" ~ "Up to high school",
                                CS_ESCOL_N == "3" ~ "High school",
                                CS_ESCOL_N == "4" ~ "College/University")) %>% 
  
  
  #EVOLUCAO   Recoded    to    2    levels (Death/Discharge).    Deaths
  # grouped as    all-cause    in-hospital    mortality.    
  # Missing    and    ignored    levels    were    considered    as    
  # missing    and    not    use    in    the    main    analysis
  
  mutate(EVOLUCAO = case_when(EVOLUCAO == 1 ~ "Discharge",
                              EVOLUCAO == 2 ~ "Death",
                              EVOLUCAO == 3 ~ "Death",
                              TRUE ~ "Ongoing")) %>%
  
  # SUPORT_VEN   Recoded    to    3    levels.    The    Ignored    level    was    
  # considered    as    missing
  
  mutate(SUPORT_VEN = case_when(SUPORT_VEN == 1 ~ "Yes, invasive",
                                SUPORT_VEN == 2 ~ "Yes, non-invasive",
                                SUPORT_VEN == 3 ~ "No")) %>%
  
  
  #========= NESSA PARTE NO SCRIPT ORIGINAL DO RANZANI =========================
#======= ABAIXO CRIA UMA FUNÇÃO PARA PARA TRANSFORMAR OS CAMPOS EM SIM E NAO==  
mutate_at(all_of(columns), function(x) {case_when(x == 1 ~ "Yes", x == 2 ~ "No")}) %>% 
  #========= TRANSFORMANDO SINTOMAS EM APENAS DOIS NIVEIS=======================
# Symptoms  Recoded    to    2    levels.    The    Ignored    level    was    
# considered    as    missing
mutate(
  SRAG_original = case_when(
    FEBRE == "Yes" &
      (TOSSE == "Yes" | GARGANTA == "Yes") &
      (DESC_RESP == "Yes" | DISPNEIA == "Yes" | SATURACAO == "Yes") ~ "Yes"),
  SRAG_original_total = case_when(
    !is.na(FEBRE) &
      (!is.na(TOSSE) | !is.na(GARGANTA)) &
      (!is.na(DESC_RESP) | !is.na(DISPNEIA) | !is.na(SATURACAO)) ~ "Not missing"),
  SRAG_sfebre = case_when(
    (TOSSE == "Yes" | GARGANTA == "Yes") &
      (DESC_RESP == "Yes" | DISPNEIA == "Yes" | SATURACAO == "Yes") ~ "Yes"),
  SRAG_sfebre_total = case_when(
    (!is.na(TOSSE) | !is.na(GARGANTA)) &
      (!is.na(DESC_RESP) | !is.na(DISPNEIA) | !is.na(SATURACAO)) ~ "Not missing")) %>% 
  mutate(
    SRAG_original = ifelse((is.na( SRAG_original) &  SRAG_original_total == "Not missing"),  "No",  SRAG_original),
    SRAG_sfebre   = ifelse((is.na( SRAG_sfebre)  &  SRAG_sfebre_total == "Not missing"),  "No",  SRAG_sfebre)) %>% 
  select(-c( SRAG_original_total,  SRAG_sfebre_total))

