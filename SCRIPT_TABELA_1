                     labels = c("Pre-pandemic","Post-pandemic")),
    
    # REGIÃO (ORDEM CORRETA)
    regiao = factor(regiao,
                    levels = c("Sul","Sudeste","Centro-Oeste","Nordeste","Norte"),
                    labels = c("South","Southeast","Central-West","Northeast","North")),
    
    # SUPORTE VENTILATÓRIO (SEGURO)
    suporte_vent = factor(suporte_vent,
                          levels = c("No","Yes, non-invasive","Yes, invasive"),
                          labels = c("No","Non-invasive","Invasive"))
  )

# =========================================================
# 2. FUNÇÃO CFR
# =========================================================

calc_cfr <- function(df) {
  if(nrow(df) == 0){
    return(list(res = "-", ob = NA, tot = NA))
  }
  
  obitos <- sum(df$obito == 1)
  total <- nrow(df)
  prop <- obitos / total
  
  res <- paste0(
    obitos, "/", total, " (",
    round(prop*100,1), "%)"
  )
  
  return(list(res = res, ob = obitos, tot = total))
}

# =========================================================
# 3. FUNÇÃO p-VALOR
# =========================================================

calc_p <- function(df) {
  
  if(nrow(df) == 0) return(NA)
  
  tab <- table(df$periodo, df$obito)
  
  if(all(dim(tab) == c(2,2))){
    
    if(any(chisq.test(tab)$expected < 5)){
      return(fisher.test(tab)$p.value)
    } else {
      return(chisq.test(tab)$p.value)
    }
    
  } else {
    return(NA)
  }
}

# =========================================================
# 4. FUNÇÃO PARA CRIAR LINHA
# =========================================================

criar_linha <- function(df, regiao_nome, categoria_nome) {
  
  pre <- calc_cfr(df %>% filter(periodo == "Pre-pandemic"))
  pos <- calc_cfr(df %>% filter(periodo == "Post-pandemic"))
  p_val <- calc_p(df)
  
  tibble(
    Region = regiao_nome,
    Category = categoria_nome,
    `Pre-pandemic` = pre$res,
    `Post-pandemic` = pos$res,
    p = p_val
  )
}

# =========================================================
# 5. CONSTRUIR TABELA
