## ====================   AQUI OPTOU-SE POR CRIAR TRES VAR QUE CLASSIFICA O DESFECHO DE UTI================================
A <- A %>%
  mutate(
    # garantir que são datas (caso ainda não sejam)
    dt_saiduti   = as.Date(dt_saiduti),
    dt_evoluca   = as.Date(dt_evoluca),
    
    uti_class_obito = case_when(
      
      # Óbito confirmado na UTI (coincidência exata de datas)
      evolucao == "Death" &
        !is.na(dt_saiduti) &
        dt_evoluca == dt_saiduti ~ "Obito_uti",
      
      # Óbito após saída da UTI (data de evolução posterior à saída)
      evolucao == "Death" &
        !is.na(dt_saiduti) &
        dt_evoluca > dt_saiduti ~ "Obito_pos_uti",
      
      # Inconsistência temporal (óbito antes da saída)
      evolucao == "Death" &
        !is.na(dt_saiduti) &
        dt_evoluca < dt_saiduti ~ "inc_temporal",
      
      # Óbito com saída de UTI ausente
      evolucao == "Death" &
        is.na(dt_saiduti) ~ "Obito_indeterminado",
      
      TRUE ~ NA_character_
    )
  )

