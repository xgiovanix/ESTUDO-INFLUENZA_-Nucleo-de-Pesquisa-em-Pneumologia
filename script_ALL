  nrow()

cat("\nCasos problemáticos identificados:\n")
cat(sprintf("  Negativos (<0 dias): %s\n", format(n_negativos, big.mark=".")))
cat(sprintf("  >365 dias: %s\n", format(n_mais_365, big.mark=".")))
cat(sprintf("  TOTAL: %s\n", format(n_absurdos, big.mark=".")))

# PASSO 5: CRIAR A NOVO (LIMPO) - SOBRESCREVENDO O ORIGINAL
A <- A_com_diagnostico %>%
  filter(!flag_absurdo) %>%  # Remove os casos problemáticos
  select(-flag_absurdo, -status, -dias_calc)  # Remove colunas auxiliares

# PASSO 6: Verificar estado final
n_final <- nrow(A)
n_removidos <- n_inicial - n_final

cat("\n----------------------------------------\n")
cat("RESUMO DA LIMPEZA:\n")
cat("----------------------------------------\n")
cat(sprintf("Casos iniciais: %s\n", format(n_inicial, big.mark=".")))
cat(sprintf("Casos problemáticos removidos: %s\n", format(n_removidos, big.mark=".")))
cat(sprintf("Casos finais: %s\n", format(n_final, big.mark=".")))
cat(sprintf("Percentual removido: %.3f%%\n", n_removidos/n_inicial*100))

# PASSO 7: Verificar se ainda existem problemas
verificacao_final <- A %>%
  mutate(dias_calc = as.integer(dt_evoluca - dt_interna)) %>%
  summarise(
    total = n(),
    negativos = sum(dias_calc < 0, na.rm = TRUE),
    mais_365 = sum(dias_calc > 365, na.rm = TRUE),
    com_na = sum(is.na(dias_calc))
  )

cat("\nVerificação final (após limpeza):\n")
print(verificacao_final)

# PASSO 8: Reporte para metodologia
cat("\n========================================\n")
cat("TEXTO PARA METODOLOGIA:\n")
cat("========================================\n")
cat(sprintf("Excluímos %s casos (%.3f%% da amostra) com tempo de internação superior a 365 dias ou negativo, considerados inconsistentes. ", 
            format(n_removidos, big.mark="."), n_removidos/n_inicial*100))
cat(sprintf("Desses, %s eram negativos e %s superiores a 365 dias. ", 
            format(n_negativos, big.mark="."), format(n_mais_365, big.mark=".")))
cat(sprintf("Os demais %s casos foram mantidos para análise.\n", 
            format(n_final, big.mark=".")))

# PASSO 9: Salvar log
log_limpeza <- data.frame(
  data = Sys.Date(),
  etapa = c("Inicial", "Após remoção"),
  n_casos = c(n_inicial, n_final),
  n_negativos = c(n_negativos, 0),
  n_mais_365 = c(n_mais_365, 0),
  total_removidos = c(0, n_removidos),
  pct_removidos = c(0, round(n_removidos/n_inicial*100, 3))
)

# Salvar como Excel
writexl::write_xlsx(log_limpeza, "log_remocao_casos_absurdos.xlsx")

cat("\n✅ Log salvo em 'log_remocao_casos_absurdos.xlsx'\n")
cat("✅ Dataset 'A' atualizado com", format(n_final, big.mark="."), "casos\n")


#==============EXPORTANTO EM CSV E EM PARQUET==============================================================================

INFLUENZA_FULL <- A

#setwd()

write_excel_csv2(INFLUENZA_FULL, 
                 "INFLUENZA_FULL_v2.csv",
                 na = "",
                 append = FALSE)

write_parquet(INFLUENZA_FULL, "INFLUENZA_FULL_v2.parquet")

