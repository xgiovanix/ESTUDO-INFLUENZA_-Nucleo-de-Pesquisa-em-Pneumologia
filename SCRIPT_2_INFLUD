#===========PARTE-02============================================================
# ESSA PARTE DO SCRIPT  TRABALHAMOS COM ADAPTAÇÕES DO SCRIPT DE RANZANI:
# https://github.com/oranzani/Ranzani_Bastos_etal_LRM_COVID19Brazil
# ESTAMOS COLAPSANDO OS NIVEIS DAS VARIAVEIS CONFORME THE LANCET, AJUSTANDO AS COMORBIDADES
# E SINTOMAS PARA AS ANALISES POSTERIORES 
# VEJA NESSE LINK O GUIA DAS VARIAVIES:
#https://www.thelancet.com/cms/10.1016/S2213-2600(20)30560-9/attachment/a8634329-c7dd-4c89-8122-12a37a07845e/mmc2.pdf
# ALGUNS SUBNIVEIS PASSAM A SER EM INGLES PARA MANTER CONSITENCIA DA SEQUENCIA DO
#SCRIPT POSTERIOR

#========= CRIANDO UM VETOR COM AS COLUNAS DE SINTOMAS PARA SEREM MANIPULADAS DEPOIS
## Columns with same options, Yes, No, Ignored, NA

columns <- c("FEBRE", "TOSSE", "GARGANTA", "DISPNEIA", "DESC_RESP",
             "SATURACAO", "DIARREIA", "VOMITO", "OUTRO_SIN", "PUERPERA",
             "CARDIOPATI", "HEMATOLOGI", "SIND_DOWN", "HEPATICA", "ASMA",
             "DIABETES", "NEUROLOGIC", "PNEUMOPATI", "IMUNODEPRE",
             "RENAL", "OBESIDADE", "OUT_MORBI")


#========= ESTOU CODIFICANDO AS VARIAVEIS CONFORME O ESTUDO DE RANZANI==========
#EM CADA VARIaVEL SEGUE A DESCRIÇÃO ============================================

INFLUENZA_FULL <- INFLUENZA_FULL %>% # AQUI NO SCRIPR RANZANI USOU-SE SRAG TOTAL (srag_adults_pcr ), EM TODO NOSSO SCRIPT SERA INFLUNZA
  # CS_SEXO Recoded    to    2    levels.    The    Ignored    level    was    
  # considered    as    missing
  mutate(CS_SEXO = case_when(CS_SEXO == "M" ~ "Male",
                             CS_SEXO == "F" ~ "Female")) %>% 
  # FAIXA DE IDADE Recoded    to    6    levels- nova variavel que categoriza as idades com base na
  # idade_anos, previamente criada pelo SCRIPT do Ministerio da Saúde
  mutate(FAIXA_IDADE = case_when(idade_anos <= 39 ~ "18-39",
                                 idade_anos <= 49 ~ "40-49",
                                 idade_anos <= 59 ~ "50-59",
                                 idade_anos <= 69 ~ "60-69",
                                 idade_anos <= 79 ~ "70-79",
                                 TRUE ~ "80+")) %>%
  
  # CS_RACA, Recoded    to    4    levels: combined    Black    and    
  # Brown;    kept    White,    Asian    and    Indigenous.    The    
  # Ignored    level    was    considered    as    missing
  
  mutate(CS_RACA = case_when(CS_RACA == "1" ~ "White",
                             CS_RACA == "2" ~ "Black/Brown",
                             CS_RACA == "3" ~ "Asian",
                             CS_RACA == "4" ~ "Black/Brown",
                             CS_RACA == "5" ~ "Indigenous")) %>% 
  
  # CS_ESCOL_N Recoded    to    4    levels.        Collapsing    the    categories    
  # of    intermediate    levels    of    education    in    “Up    to # high    school”    (included    middle    and    elementary    
  #school).    The    Ignored    level    was    considered    as missing
  
  mutate(CS_ESCOL_N = case_when(CS_ESCOL_N == "0" ~ "Illiterate",   # Not applicable not present in this filtered adults dataset
                                CS_ESCOL_N == "1" ~ "Up to high school",
                                CS_ESCOL_N == "2" ~ "Up to high school",
                                CS_ESCOL_N == "3" ~ "High school",
                                CS_ESCOL_N == "4" ~ "College/University")) %>% 
  
  
  #EVOLUCAO   Recoded    to    2    levels (Death/Discharge).    Deaths
  # grouped as    all-cause    in-hospital    mortality.    
  # Missing    and    ignored    levels    were    considered    as    
  # missing    and    not    use    in    the    main    analysis
  
  mutate(EVOLUCAO = case_when(EVOLUCAO == 1 ~ "Discharge",
                              EVOLUCAO == 2 ~ "Death",
                              EVOLUCAO == 3 ~ "Death",
                              TRUE ~ "Ongoing")) %>%
  
  # SUPORT_VEN   Recoded    to    3    levels.    The    Ignored    level    was    
  # considered    as    missing
  
  mutate(SUPORT_VEN = case_when(SUPORT_VEN == 1 ~ "Yes, invasive",
                                SUPORT_VEN == 2 ~ "Yes, non-invasive",
                                SUPORT_VEN == 3 ~ "No")) %>%
  
  
  #========= NESSA PARTE NO SCRIPT ORIGINAL DO RANZANI =========================
  #======= ABAIXO CRIA UMA FUNÇÃO PARA PARA TRANSFORMAR OS CAMPOS EM SIM E NAO==  
    mutate_at(all_of(columns), function(x) {case_when(x == 1 ~ "Yes", x == 2 ~ "No")}) %>% 
  #========= TRANSFORMANDO SINTOMAS EM APENAS DOIS NIVEIS=======================
  # Symptoms  Recoded    to    2    levels.    The    Ignored    level    was    
  # considered    as    missing
  mutate(
    SRAG_original = case_when(
      FEBRE == "Yes" &
        (TOSSE == "Yes" | GARGANTA == "Yes") &
        (DESC_RESP == "Yes" | DISPNEIA == "Yes" | SATURACAO == "Yes") ~ "Yes"),
    SRAG_original_total = case_when(
      !is.na(FEBRE) &
        (!is.na(TOSSE) | !is.na(GARGANTA)) &
        (!is.na(DESC_RESP) | !is.na(DISPNEIA) | !is.na(SATURACAO)) ~ "Not missing"),
    SRAG_sfebre = case_when(
      (TOSSE == "Yes" | GARGANTA == "Yes") &
        (DESC_RESP == "Yes" | DISPNEIA == "Yes" | SATURACAO == "Yes") ~ "Yes"),
    SRAG_sfebre_total = case_when(
      (!is.na(TOSSE) | !is.na(GARGANTA)) &
        (!is.na(DESC_RESP) | !is.na(DISPNEIA) | !is.na(SATURACAO)) ~ "Not missing")) %>% 
  mutate(
    SRAG_original = ifelse((is.na( SRAG_original) &  SRAG_original_total == "Not missing"),  "No",  SRAG_original),
    SRAG_sfebre   = ifelse((is.na( SRAG_sfebre)  &  SRAG_sfebre_total == "Not missing"),  "No",  SRAG_sfebre)) %>% 
  select(-c( SRAG_original_total,  SRAG_sfebre_total))

#========= CRIA COLUNA INDEX DE 1 ATE O N TOTAL DE LINHAS=======================
INFLUENZA_FULL <- INFLUENZA_FULL %>% 
  mutate(index = 1:n())
View(INFLUENZA_FULL)
#========= AJUSTE PARA DETERMINAR SE COMORBIDADE OU NAO=========================
## comorbidities / symptons

# keeping the original with missing values, generating new with real missing sufix _m
db_temp <- INFLUENZA_FULL %>% select(index, all_of(columns))
db_temp <- db_temp %>% rename_at(all_of(columns), function(x) paste0(x, "_m"))

INFLUENZA_FULL <-  INFLUENZA_FULL %>% left_join(db_temp, by = "index")

# now considering missing as No for commorbidities only

comorbidades <-  c("PUERPERA", "CARDIOPATI", "HEMATOLOGI",
                   "SIND_DOWN", "HEPATICA", "ASMA",
                   "DIABETES", "NEUROLOGIC", "PNEUMOPATI",
                   "IMUNODEPRE", "RENAL", "OBESIDADE", "OUT_MORBI")

INFLUENZA_FULL <-  INFLUENZA_FULL %>% 
  mutate(PUERPERA = case_when(CS_SEXO == "Male" ~ NA_character_, TRUE ~ PUERPERA), # few missing considered as entered for puerpera
         CS_SEXO  = case_when(PUERPERA == "Yes" ~ "Female", TRUE ~ CS_SEXO)) %>%  # 1 case puerpera with missing sex
  
  #========= AJUSTA COMORBIDADE PARA: NENHUMA, 1 A 2, OU MAIS DE DUAS=========== 
  # Este código está criando 3 versões diferentes da contagem de comorbidades
  # # com tratamentos distintos para valores faltantes (NA)
  
  # Dados originais (com NA)
  #           ↓
  # [Tratamento de NA]
  #   ├─── Otimista: NA = 0
  #   ├─── Intermediário: NA só se tudo NA
  #   └─── Conservador: NA se algum NA
  #           ↓
  # [Calcula soma de comorbidades]
  #           ↓
  # [Categoriza: 0, 1-2, 3+]
  
  
  mutate_at(all_of(comorbidades), function(x){case_when(x == "Yes" ~ 1,
                                                        TRUE ~ 0)}) %>%
  mutate(
    CONT_COMORB = CARDIOPATI + HEMATOLOGI +  HEPATICA + DIABETES +
      NEUROLOGIC + PNEUMOPATI + IMUNODEPRE + RENAL +
      OBESIDADE,
    
    n_comorb = case_when(
      CONT_COMORB == 0 ~ 0,
      CONT_COMORB == 1 ~ 1,
      CONT_COMORB == 2 ~ 1,
      CONT_COMORB >  2 ~ 2)
  ) %>% 
  mutate(
    CONT_COMORB_m = case_when(
      is.na(CARDIOPATI_m) & is.na(HEMATOLOGI_m) & is.na(HEPATICA_m) &
        is.na(DIABETES_m) & is.na(NEUROLOGIC_m) & is.na(PNEUMOPATI_m) &
        is.na(IMUNODEPRE_m) & is.na(RENAL_m) & is.na(OBESIDADE_m) ~ NA_real_,
      TRUE ~ CONT_COMORB
    ),
    n_comorb_m = case_when(
      CONT_COMORB_m == 0 ~ 0,
      CONT_COMORB_m == 1 ~ 1,
      CONT_COMORB_m == 2 ~ 1,
      CONT_COMORB_m >  2 ~ 2),
    
  ) %>% 
  mutate(CONT_COMORB_mreal = case_when(!is.na(CARDIOPATI_m) & !is.na(HEMATOLOGI_m) & !is.na(HEPATICA_m) &
                                         !is.na(DIABETES_m) & !is.na(NEUROLOGIC_m) & !is.na(PNEUMOPATI_m) &
                                         !is.na(IMUNODEPRE_m) & !is.na(RENAL_m) & !is.na(OBESIDADE_m) ~ CONT_COMORB,
                                       TRUE ~ NA_real_
  ),
  n_comorb_mreal = case_when(
    CONT_COMORB_mreal == 0 ~ 0,
    CONT_COMORB_mreal == 1 ~ 1,
    CONT_COMORB_mreal == 2 ~ 1,
    CONT_COMORB_mreal >  2 ~ 2))


view(INFLUENZA_FULL)

