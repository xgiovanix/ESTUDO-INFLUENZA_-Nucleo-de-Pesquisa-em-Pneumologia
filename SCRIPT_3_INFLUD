#================== NESSA ETAPA ESTOU VERIFICANDO CASOS ABSURDOS EM RELAÇAO A DATA DE INTERNAÇÂO E DE EVOLUÇÂO =========
# ======================================================================================================================
# SCRIPT  LIMPEZA DE DADOS - REMOÇÃO DE CASOS COM TEMPO DE INTERNAÇÃO >365 DIAS
# ======================================================================================================================
# OBJETIVO: Identificar e excluir registros com tempo de internação 
#           superior a 365 dias, considerados inconsistentes para análise
#
# DATASET ENTRADA: A (após merge dos anos 2019-2025)
# DATASET SAÍDA: A_com_diagnostico - > A -> INFLUENZA (limpo)
# ARQUIVOS GERADOS: log_remocao_casos_absurdos.csv
#
# AUTOR: Giovani B Costa
# VERSÃO: 2.0
# DATA: 16/02/2026
# ========================================================================================================================
# ESTATÍSTICAS:
# - Casos iniciais: 574.388
# - Casos >365 dias removidos: 368 (0,064%)
# - Casos finais: 574.020
# ========================================================================================================================
x <- A

# Identificar os 50 piores casos de internação
casos_inte_absurdos <- x %>% 
  filter(!is.na(dt_interna) & !is.na(dt_evoluca)) %>% 
  mutate(dias_calc = as.integer(dt_evoluca - dt_interna)) %>% 
  filter(dias_calc > 365 | dias_calc < 0) %>%  # >1 ano ou negativo
  select(id_municip, dt_interna, dt_evoluca, dias_calc, evolucao, ano) %>% 
  arrange(desc(dias_calc)) %>% 
  head(1000)

# Visualizar
View(casos_inte_absurdos)

# # A tibble: 2 × 7
# tipo         n     pct media mediana   min   max
# <chr>    <int>   <dbl> <dbl>   <dbl> <int> <int>
#   1 > 1 ano    368  0.0661 484.     388.   366  3342
# 2 Normal  556023 99.9     15.7     11      0   365


# PASSO 1: Registrar estado inicial
n_inicial <- nrow(A)
cat("========================================\n")
cat("PROCESSO DE LIMPEZA - CASOS >365 DIAS E NEGATIVOS\n")
cat("========================================\n")
cat("Estado inicial:\n")
cat("  Total de casos:", n_inicial, "\n")

# PASSO 2: Identificar os casos problemáticos
A_com_diagnostico <- A %>%
  mutate(
    dias_calc = as.integer(dt_evoluca - dt_interna),
    flag_absurdo = !is.na(dias_calc) & (dias_calc > 365 | dias_calc < 0),
    status = case_when(
      is.na(dias_calc) ~ "Sem data completa",
      dias_calc < 0 ~ "Negativo",
      dias_calc >= 0 & dias_calc <= 365 ~ "Normal (≤365 dias)",
      dias_calc > 365 ~ "Absurdo (>365 dias)"
    )
  )

# PASSO 3: Sumarizar antes da remoção
sumario_antes <- A_com_diagnostico %>%
  group_by(status) %>%
  summarise(
    n = n(),
    pct = n / n_inicial * 100
  )

cat("\nComposição inicial:\n")
print(sumario_antes)

# PASSO 4: Contar os casos problemáticos
n_absurdos <- A_com_diagnostico %>%
  filter(flag_absurdo) %>%
  nrow()

n_negativos <- A_com_diagnostico %>%
  filter(!is.na(dias_calc) & dias_calc < 0) %>%
  nrow()

n_mais_365 <- A_com_diagnostico %>%
  filter(!is.na(dias_calc) & dias_calc > 365) %>%
  nrow()

cat("\nCasos problemáticos identificados:\n")
cat(sprintf("  Negativos (<0 dias): %s\n", format(n_negativos, big.mark=".")))
cat(sprintf("  >365 dias: %s\n", format(n_mais_365, big.mark=".")))
cat(sprintf("  TOTAL: %s\n", format(n_absurdos, big.mark=".")))

# PASSO 5: CRIAR A NOVO (LIMPO) - SOBRESCREVENDO O ORIGINAL
A <- A_com_diagnostico %>%
  filter(!flag_absurdo) %>%  # Remove os casos problemáticos
  select(-flag_absurdo, -status, -dias_calc)  # Remove colunas auxiliares

# PASSO 6: Verificar estado final
n_final <- nrow(A)
n_removidos <- n_inicial - n_final

cat("\n----------------------------------------\n")
cat("RESUMO DA LIMPEZA:\n")
cat("----------------------------------------\n")
cat(sprintf("Casos iniciais: %s\n", format(n_inicial, big.mark=".")))
cat(sprintf("Casos problemáticos removidos: %s\n", format(n_removidos, big.mark=".")))
cat(sprintf("Casos finais: %s\n", format(n_final, big.mark=".")))
cat(sprintf("Percentual removido: %.3f%%\n", n_removidos/n_inicial*100))

# PASSO 7: Verificar se ainda existem problemas
verificacao_final <- A %>%
  mutate(dias_calc = as.integer(dt_evoluca - dt_interna)) %>%
  summarise(
    total = n(),
    negativos = sum(dias_calc < 0, na.rm = TRUE),
    mais_365 = sum(dias_calc > 365, na.rm = TRUE),
    com_na = sum(is.na(dias_calc))
  )

cat("\nVerificação final (após limpeza):\n")
print(verificacao_final)

# PASSO 8: Reporte para metodologia
cat("\n========================================\n")
cat("TEXTO PARA METODOLOGIA:\n")
cat("========================================\n")
cat(sprintf("Excluímos %s casos (%.3f%% da amostra) com tempo de internação superior a 365 dias ou negativo, considerados inconsistentes. ", 
            format(n_removidos, big.mark="."), n_removidos/n_inicial*100))
cat(sprintf("Desses, %s eram negativos e %s superiores a 365 dias. ", 
            format(n_negativos, big.mark="."), format(n_mais_365, big.mark=".")))
cat(sprintf("Os demais %s casos foram mantidos para análise.\n", 
            format(n_final, big.mark=".")))

# PASSO 9: Salvar log
log_limpeza <- data.frame(
  data = Sys.Date(),
  etapa = c("Inicial", "Após remoção"),
  n_casos = c(n_inicial, n_final),
  n_negativos = c(n_negativos, 0),
  n_mais_365 = c(n_mais_365, 0),
  total_removidos = c(0, n_removidos),
  pct_removidos = c(0, round(n_removidos/n_inicial*100, 3))
)

# Salvar como Excel
writexl::write_xlsx(log_limpeza, "log_remocao_casos_absurdos.xlsx")

