  ##    ---- RINOVÍRUS ----
  # ..........................................................................................
  
  # Criando classificação de Rinovírus (caso)
  df$rinovirus_caso_unico <- ifelse(df$rinovirus_caso == 1 & 
                                      df$codeteccao_casos == 0, 1, 0)
  # Verificando o total de observações
  table(df$rinovirus_caso_unico, df$ano)
  
  # Criando a classificação de Rinovírus (óbito)
  df$rinovirus_obito_unico <- ifelse(df$rinovirus_caso_unico == 1 &
                                       df$EVOLUCAO == 2, 1, 0)
  # Verificando o total de observações
  table(df$rinovirus_obito_unico, df$ano)
  
  # ..........................................................................................
  ##    ---- PARAINFLUENZA ----
  # ..........................................................................................
  
  # Criando classificação de Parainfluenza (caso)
  df$parainfluenza_caso_unico <- ifelse(df$parainfluenza_caso == 1 & 
                                          df$codeteccao_casos == 0, 1, 0)
  # Verificando o total de observações
  table(df$parainfluenza_caso_unico, df$ano)
  
  # Criando a classificação de Parainfluenza (óbito)
  df$parainfluenza_obito_unico <- ifelse(df$parainfluenza_caso_unico == 1 &
                                           df$EVOLUCAO == 2, 1, 0)
  # Verificando o total de observações
  table(df$parainfluenza_obito_unico, df$ano)
  
  
  # ..........................................................................................
  ##    ----  METAPNEUMOVÍRUS ----
  # ..........................................................................................
  
  
  # Criando classificação de Metapneumovírus (caso)
  df$metapneumo_caso_unico <- ifelse(df$metapneumo_caso == 1 &
                                       df$codeteccao_casos == 0, 1, 0)
