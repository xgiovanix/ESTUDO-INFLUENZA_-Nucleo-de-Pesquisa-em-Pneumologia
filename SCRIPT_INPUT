# Etapa 1 — Análise do Padrão de Missing
# 2.1 Proporção de missing por variável

prop_miss <- colMeans(is.na(INFLUENZA_INPUT))
sort(prop_miss, decreasing = TRUE)

# 2.2 Teste de associação MAR

# Para cada variável _m_m2:
  
  vars_miss <- grep("_m_m2$", names(INFLUENZA_INPUT), value = TRUE)

results_mar <- lapply(vars_miss, function(v){
  
  miss_var <- as.numeric(is.na(INFLUENZA_INPUT[[v]]))
  
  fit <- glm(miss_var ~ age_cat + sex + region + h_out + capital,
             family = binomial,
             data = INFLUENZA_INPUT)
  
  data.frame(
    variable = v,
    AIC = AIC(fit),
    McFadden_R2 = 1 - fit$deviance/fit$null.deviance
  )
})

do.call(rbind, results_mar)
