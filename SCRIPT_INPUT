# Missing data were handled using multiple imputation by chained equations 
# under a missing at random assumption. Thirty imputed datasets were generated
# using logistic and multinomial logistic regression models according to 
# variable type. Imputation models included demographic, clinical, and regional
# predictors associated with missingness. Estimates were combined 
# using Rubin’s rules.

#====================INICIANDO MODELO PARA IMPUTAÇÂO=================

ini  <- mice(INFLUENZA_INPUT, maxit = 0)
meth <- ini$method
pred <- ini$predictorMatrix
meth[] <- ""

#====================INICIANDO MODELO PARA IMPUTAÇÂO=================

vars_logit <- c("sex","sari",
                "cardiopati_m_m2","hematologi_m_m2","hepatica_m_m2","diabetes_m_m2",
                "neurologic_m_m2","pneumopati_m_m2","imunodepre_m_m2",
                "renal_m_m2","obesidade_m_m2",  "asma_m_m2", "sind_down_m_m2", "puerpera_m_m2",
                "saturacao_m_m2","desc_resp_m_m2","dispneia_m_m2","out_morbi_m_m2")
meth[vars_logit] <- "logreg" # regressão logística binária


vars_mlogit <- c("resp_sup","race","time_sh")
meth[vars_mlogit] <- "polyreg"


#VARIAVEIS COMMPLETAS NAO IMPUTADAS
vars_regular <- c("index","evolucao","sem_pri",
                  "age_cat","nu_idade_n",
                  "capital","region","h_out")

meth[vars_regular] <- ""

#Ajustar matriz de preditores

pred[,] <- 0

predictors_used <- c("h_out","age_cat","sem_pri","capital","region","nu_idade_n")

pred[vars_logit, predictors_used]  <- 1
pred[vars_mlogit, predictors_used] <- 1

#Garantir que variável não se prediga:
diag(pred) <- 0

options(mice.nnet.maxit = 50)
options(mice.nnet.trace = FALSE)



#Rodar imputação (equivalente ao mi impute chained)

imp <- mice(INFLUENZA_INPUT,
            m = 20,
            method = meth,
