is_sf <- inherits(x, "sf")
print(paste("É objeto sf?", is_sf))

# 2. Verificar colunas
names(x)

# 3. Tentar converter explicitamente
x_sf <- st_as_sf(x, sf_column_name = "geom")

# 4. Verificar geometrias válidas
validas <- st_is_valid(x_sf)
print(paste("Geometrias válidas:", all(validas)))

# Se houver geometrias inválidas, tentar corrigir
if(!all(validas)) {
  x_sf <- st_make_valid(x_sf)
}

