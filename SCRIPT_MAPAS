x <- read_parquet("/Users/xgx/Desktop/DOUTORADO/INFLUENZA/INFLUENZA_FULL_FINAL_v2.parquet")

#===================CARREGANDO MAPAS
map <- geobr::read_state()
names(map)

#===================FILTRANDO DADOS DO INFLUENZA P MAPA
vacina_map <- x %>% 
  select(vacina, sg_uf_internacao_final, ano)
  
#===================SUMMARIZANDO ESTATISTICAS

percen_vacinado <- vacina_map %>% 
  group_by(sg_uf_internacao_final, ano) %>% 
  summarise(
    total = n(),
    vacinados = sum(vacina=="1", na.rm = TRUE),
    nao_vacinados = sum(vacina=="2", na.rm = TRUE),
    ignorado = sum(vacina=="9" | is.na(vacina), na.rm = TRUE),
    porc_vacin = (vacinados/total) * 100,
    porc_n_vacin = (nao_vacinados/total) * 100,
    porc_ig_miss = (ignorado/total) * 100
  )

#===================FAZENDO JUNCAO DADOS MAPAS COM DATASET
percen_vacinado <- percen_vacinado %>% 
  rename(abbrev_state=sg_uf_internacao_final)
  
map_final <- left_join(map, percen_vacinado)

