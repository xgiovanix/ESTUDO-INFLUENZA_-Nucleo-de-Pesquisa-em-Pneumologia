  # Criando a classificação de Outros vírus (óbito)
  df$outros_virus_obito_unico <- ifelse(df$outros_virus_caso_unico == 1 &
                                          df$EVOLUCAO == 2, 1, 0)
  # Verificando o total de observações
  table(df$outros_virus_obito_unico, df$ano)
  
  # ..........................................................................................
  ##            ----  OVR (Outros vírus respiratórios + Adeno + Boca + Meta + Rino) ----
  # ..........................................................................................
  
  # Criando classificação de OVR (caso)
  df$ovr_caso_unico <- ifelse(df$ovr_caso == 1 &
                                df$codeteccao_casos == 0, 1, 0)
  # Verificando o total de observações
  table(df$ovr_caso_unico, df$ano)
  
  
  # Criando a classificação de OVR (óbito)
  df$ovr_obito_unico <- ifelse(df$ovr_caso_unico == 1 & 
                                 df$EVOLUCAO == 2, 1, 0)
  # Verificando o total de observações
  table(df$ovr_obito_unico, df$ano)
  
  # ..........................................................................................
  ##                       ----  FATOR DE RISCO ----
  # ..........................................................................................
  
  # Criando uma nova variável chamada 'fator_risco' dentro do data frame 'df'
  # Essa variável vai indicar se a pessoa possui algum fator de risco (1) ou não (0)
  
  df$fator_risco <- ifelse(
    
    # A função ifelse avalia a condição abaixo e retorna 1 (se for verdadeira) ou 0 (se for falsa)
    
    df$ASMA == 1 |           # Tem asma
      df$FATOR_RISC == 1 |     # Marcou algum fator de risco geral
      df$CARDIOPATI == 1 |     # Tem cardiopatia (doença cardíaca)
      df$MORB_DESC == 1 |      # Outra comorbidade descrita
      df$DIABETES == 1 |       # Tem diabetes
      df$HEMATOLOGI == 1 |     # Tem doença hematológica
      df$HEPATICA == 1 |       # Tem doença hepática (do fígado)
      df$IMUNODEPRE == 1 |     # É imunodeprimido
      df$NEUROLOGIC == 1 |     # Tem doença neurológica
      df$OBES_IMC == 1 |       # Obesidade (informada via IMC)
      df$OBESIDADE == 1 |      # Obesidade (informada diretamente)
      df$OUT_MORBI == 1 |      # Outra morbidade
      df$PNEUMOPATI == 1 |     # Tem pneumopatia (doença pulmonar)
      df$PUERPERA == 1 |       # Está no período puerperal (após o parto)
      df$RENAL == 1 |          # Tem doença renal
      df$SIND_DOWN == 1 |      # Tem síndrome de Down
      df$TABAG == 1,           # É tabagista (fuma)
    
    1,  # Se alguma das condições acima for verdadeira, atribui 1 (tem fator de risco)
    0   # Caso contrário, atribui 0 (não tem fator de risco)
  )
  
  # Verificando o total de observações
  table(df$fator_risco)
  
  # ..........................................................................................
  ##                       ---- MANIPULAÇAO DAS VARIÁVEIS CRIADAS ----
  # ..........................................................................................
  
  # Lista de variáveis para substituir NA por 0
  variaveis_para_substituir <- c('out_agentes',
                                 'out_agentes_obito',
                                 'n_detectado',
                                 'investigacao',
                                 'investigacao_obito',
                                 'srag_n_especificada',
                                 'fator_risco',
                                 'srag_n_especificada_obito')
  
  # Substituir NA por 0 nas variáveis listadas
  df <- df %>%
    mutate(across(all_of(variaveis_para_substituir), ~ ifelse(is.na(.), 0, .)))
  
  # ..........................................................................................
  ##                       ---- CRIANDO A SRAG TOTAL ----
  # ..........................................................................................
  
  # Criando uma nova variável chamada 'srag_total_casos' na base 'df'
  # Essa variável indica se o caso foi causado por algum agente etiológico de SRAG
  # A variável será 1 se o caso for positivo para qualquer uma das categorias listadas, e 0 caso contrário
  
  df <- df %>%
    mutate(
      srag_total_casos = if_else(
        covid_caso_unico == 1 |                     # Caso único de COVID-19
          influenza_geral_unico == 1 |                # Caso único de Influenza (geral)
          vsr_caso_unico == 1 |                       # Caso único de Vírus Sincicial Respiratório (VSR)
          rinovirus_caso_unico == 1 |                 # Caso único de Rinovírus
          ovr_caso_unico == 1 |                       # Caso único de Outros Vírus Respiratórios (OVR)
          investigacao == 1 |                         # Caso ainda em investigação
          out_agentes == 1 |                          # Causado por outros agentes (não especificados acima)
          srag_n_especificada == 1 |                  # SRAG não especificada
          codeteccao_casos == 1,                      # Codetecção (dois ou mais agentes detectados)
        1,                                          # Se qualquer uma das condições acima for verdadeira, atribui 1
        0                                           # Caso contrário, atribui 0
      )
    )
  
  # Exibindo uma tabela de frequência da nova variável srag_total_casos (para verificar a distribuição dos valores)
  table(df$srag_total_casos)
  
  
  # Criando agora a variável 'srag_total_obitos', com lógica semelhante à de casos
  # Essa variável indica se houve óbito associado a qualquer uma das causas listadas
  
  df <- df %>%
    mutate(
      srag_total_obitos = if_else(
        covid_obito_unico == 1 |                    # Óbito por COVID-19 (único agente)
          influenza_geral_obito_unico == 1 |          # Óbito por Influenza (geral)
          vsr_obito_unico == 1 |                      # Óbito por VSR
          ovr_obito_unico == 1 |                      # Óbito por outros vírus respiratórios
          rinovirus_obito_unico == 1 |                # Óbito por Rinovírus
          investigacao_obito == 1 |                   # Óbito em investigação
          out_agentes_obito == 1 |                    # Óbito por outros agentes
          srag_n_especificada_obito == 1 |            # Óbito por SRAG não especificada
          codeteccao_obito == 1,                      # Óbito com codetecção
        1,                                          # Atribui 1 se houver qualquer condição verdadeira
        0                                           # Caso contrário, atribui 0
      )
    )
  
  # Exibindo uma tabela de frequência da variável srag_total_obitos
  table(df$srag_total_obitos)
  
  
  # Exportação
  nome_base <- gsub("df_", "", nome_df)
  
  # Exceção: df_2025 com SEM_PRI
  if (nome_df == "df_2025") {
    ultimo_sempri <- max(as.numeric(df$SEM_PRI), na.rm = TRUE)
    nome_base <- paste0("2025_", ultimo_sempri)
  }
  
  # Salvar
  write_csv2(df, paste0(path_csv, nome_base, ".csv"))
  save(df, file = paste0(path_rdata, nome_base, ".RData"))
  write_parquet(df, paste0(path_parquet, nome_base, ".parquet"))
  
  
  message("✔ Banco ", nome_df, " exportado com sucesso!")
}

