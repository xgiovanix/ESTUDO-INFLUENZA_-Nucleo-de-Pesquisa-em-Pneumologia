library(janitor)
library(DiagrammeR)


#1_IMPORTANDO DADO BRUTO INFLUD
influd15 <- read.csv("C:/Users/xgx/Documents/INFLUENZA_2026/INFLUENZA/data_/data_original/influd/INFLUD15.csv", sep = ";")
influd16 <- read.csv("C:/Users/xgx/Documents/INFLUENZA_2026/INFLUENZA/data_/data_original/influd/INFLUD16.csv", sep = ";")
influd17 <- read.csv("C:/Users/xgx/Documents/INFLUENZA_2026/INFLUENZA/data_/data_original/influd/INFLUD17.csv", sep = ";")
influd18 <- read.csv("C:/Users/xgx/Documents/INFLUENZA_2026/INFLUENZA/data_/data_original/influd/INFLUD18.csv", sep = ";")

lista <-  list(influd15,influd16,influd17,influd18)
influenza_old <- bind_rows(lista)
view(influenza_old)
n_row1 <- nrow(influenza_old)
cat("\nNumero e registros totais de 2015 a 2018:", paste0(n_row1))

#2_VERIFICANDO CLASSE VARIAVEIS SRAG
class(influenza_old$HOSPITAL)
class(influenza_old$EVOLUCAO)
class(influenza_old$TOSSE)
class(influenza_old$GARGANTA)
class(influenza_old$DISPNEIA)
class(influenza_old$SATURACAO)
class(influenza_old$DESC_RESP)

#3_CRIANDO CRITERIO SRAG MIISTERIO SAUDE
influenza_old <- influenza_old %>%
  mutate(criterio_1 = (HOSPITAL == 1 | EVOLUCAO == 2)) %>%
  mutate(criterio_2 = (TOSSE == 1 | GARGANTA == 1)) %>%
  mutate(criterio_3 = (DISPNEIA == 1 | SATURACAO == 1 | DESC_RESP == 1)) %>%
  mutate(caso_srag = (criterio_1 & criterio_2 & criterio_3)) %>%
  filter(caso_srag == 1)

n_row2 <- nrow(influenza_old)
cat("\nNumero e registros totais com SRAG de 2015 a 2018:", paste0(n_row2))

#4_CRIANDO VARIAVEIS COMPATIVEIS INFLUENZA APOS 2019
#4.1_ IDADE
influenza_old <- influenza_old %>%  
  mutate(  
    NU_IDADE_N = as.numeric(NU_IDADE_N),  
    TIPO_IDADE = floor(NU_IDADE_N / 1000),  
    VALOR_IDADE = NU_IDADE_N %% 1000,  
    IDADE = case_when(  
      TIPO_IDADE == 1 ~ VALOR_IDADE / 24,  # Horas para anos  
      TIPO_IDADE == 2 ~ VALOR_IDADE / 365, # Dias para anos  
      TIPO_IDADE == 3 ~ VALOR_IDADE / 12,  # Meses para anos  
      TIPO_IDADE == 4 ~ VALOR_IDADE,     
      TRUE ~ NA_real_  
    )  
  ) %>%  
  filter(IDADE >= 18) %>%  
  select(  
    IDADE, everything(), -TIPO_IDADE, -VALOR_IDADE, -NU_IDADE_N  
  )  
n_row3 <- nrow(influenza_old)
cat("\nNumero e registros >= 18 anos com SRAG de 2015 a 2018:", paste0(n_row3))

influenza_old <-  influenza_old %>% 
  filter(UTI ==1)

n_row4 <- nrow(influenza_old)
cat("\nNumero e registros >= 18 anos, apenas UTI e com SRAG de 2015 a 2018:", paste0(n_row4))

influenza_old <- influenza_old %>% 
  filter(EVOLUCAO %in% c(1,2))


n_row5 <- nrow(influenza_old)
cat("\nNumero e registros >= 18 anos, apenas UTI e, desfecho conhecido e com SRAG de 2015 a 2018:", paste0(n_row5))

unique(influenza_old$EVOLUCAO)
#4.2 SUPORTE VENTILATORIO
influenza_old <- influenza_old %>%  
  mutate(SUPORT_VEN = case_when(  
    SUPORT_VEN == 1 ~ "No",  
    SUPORT_VEN == 2 ~ "Yes, invasive",  
    SUPORT_VEN == 3 ~ "Yes, non-invasive", 
    TRUE ~ NA_character_  
  ))  

#4.3 CS_SEXO  
influenza_old <- influenza_old %>%  
  mutate(CS_SEXO = case_when(  
    CS_SEXO == "F" ~ "Female",  
    CS_SEXO == "M" ~ "Male",  
    TRUE ~ NA_character_
  ))

#4.4 CS_ESCOLARIDADE
influenza_old <- influenza_old %>%  
  mutate(CS_ESCOL_N = case_when(
    CS_ESCOL_N == "0" ~ "Illiterate",         # Analfabeto
    CS_ESCOL_N == "1" ~ "Up to high school",  # Fundamental
    CS_ESCOL_N == "2" ~ "High school",        # Médio
    CS_ESCOL_N == "3" ~ "College/University", # Superior
    TRUE ~ NA_character_                       # 9, 10 e outros viram NA
  ))

#4.5 CS_RACA
influenza_old <- influenza_old %>%  
  mutate(CS_RACA = case_when(CS_RACA == "1" ~ "White",
                             CS_RACA == "2" ~ "Black/Brown",
                             CS_RACA == "3" ~ "Asian",
                             CS_RACA == "4" ~ "Black/Brown",
                             CS_RACA == "5" ~ "Indigenous",
                             TRUE ~ NA_character_
  )) 

#4.6 EVOLUCAO
influenza_old <- influenza_old %>% 
  mutate(EVOLUCAO = case_when(EVOLUCAO == 1 ~ "Discharge",
                              EVOLUCAO == 2 ~ "Death",
                              TRUE ~ NA_character_
  ))


unique(influenza_old$EVOLUCAO)
#CRIANDO CIDADE ESTADO E REGIAO
influenza_old <- influenza_old %>% 
  mutate(
    cidade = CO_MU_INTE,
    estado = coalesce(SG_UF,SG_UF_NOT)
  )

influenza_old <- influenza_old %>%  
  mutate(  
    estado = as.character(SG_UF),  
    regiao = case_when(  
      estado %in% c("11", "12", "13", "14", "15", "16", "17") ~ "Norte",  
      estado %in% c("21", "22", "23", "24", "25", "26", "27", "28", "29") ~ 
        "Nordeste",  
      estado %in% c("31", "32", "33", "35") ~ "Sudeste",  
      estado %in% c("41", "42", "43") ~ "Sul",  
      estado %in% c("50", "51", "52", "53") ~ "Centro-Oeste",  
      TRUE ~ NA_character_
    ))

#CRIANDO INDICE
influenza_old <- influenza_old %>% 
  mutate(
    indice = row_number()
  )

influenza_old_2 <- influenza_old %>% 
  mutate(
    DT_INTERNA = dmy(DT_INTERNA),
    DT_SIN_PRI = dmy(DT_SIN_PRI),
    DT_NOTIFIC = dmy(DT_NOTIFIC)
    
  )


#CRIANDO TEMO DE SINTOMASS
influenza_old_2$CO_MU_INTE = as.double(influenza_old_2$CO_MU_INTE)
influenza_old_2 <- influenza_old_2 %>% 
  mutate(
    TIME_SYMPTOMS_HOSP = as.numeric(DT_INTERNA - DT_SIN_PRI),
    TIME_SYMPTOMS_NOTIF = as.numeric(DT_NOTIFIC - DT_SIN_PRI)
  ) %>% 
  mutate(
    TIME_SYMPTOMS_HOSP = ifelse(TIME_SYMPTOMS_HOSP < 0, NA, TIME_SYMPTOMS_HOSP),
    TIME_SYMPTOMS_NOTIF = ifelse(TIME_SYMPTOMS_NOTIF < 0, NA, TIME_SYMPTOMS_NOTIF)
  ) %>% 
  #CRIANDO CAPITAL
  left_join(
    read_csv("https://raw.githubusercontent.com/kelvins/Municipios-Brasileiros/main/csv/municipios.csv") %>% 
      mutate(codigo_ibge_6dig = as.numeric(str_sub(codigo_ibge, 1, 6))) %>%
      select(capital, codigo_ibge_6dig), 
    by = c("CO_MU_INTE" = "codigo_ibge_6dig")
  ) %>% 
  mutate(IS_CAPITAL = ifelse(capital == 1, "Yes", "No"))



#Limitando sintomas a 60 dias
influenza_old_2 <- influenza_old_2 %>%
  mutate(
    TIME_SYMPTOMS_HOSP = case_when(
      TIME_SYMPTOMS_HOSP < 0 ~ NA_real_,
      TIME_SYMPTOMS_HOSP > 60 ~ NA_real_,
      TRUE ~ TIME_SYMPTOMS_HOSP
    )
  )
#CONTAR COMORBIDADE

comorbidades <-  c(
  "CARDIOPATI", "HEPATICA", "METABOLICA", "NEUROLOGIC", "PNEUMOPATI", "RENAL", "IMUNODEPRE", 
  "SIND_DOWN", "PUERPERA", "OUT_MORBI", "OBESIDADE"
)

#RECODIFICANDO AS COMORBIDADES
influenza_old_3 <- influenza_old_2 %>% 
  mutate_at(all_of(comorbidades), function(x) {case_when(x == 1 ~ "Yes", x == 2 ~ "No")})

#CRIANDO CENARIO OTIMISTA ONDE OS NA SAO NAO
influenza_old_4 <- influenza_old_3 %>% 
  mutate_at(all_of(comorbidades), function(x){case_when(x == "Yes" ~ 1,
                                                        TRUE ~ 0)}) %>%
  mutate(
    qtd_comorbidade = CARDIOPATI + HEPATICA + METABOLICA + NEUROLOGIC + PNEUMOPATI + RENAL + IMUNODEPRE 
    + SIND_DOWN + PUERPERA + OUT_MORBI + OBESIDADE
  )

unique(influenza_old_4$RES_FLUA)
unique(influenza_old_4$RES_FLUB)

class(influenza_old_4$RES_FLUA)
class(influenza_old_4$RES_FLUB)

#CRIANDO COLUNA INFLUENZA
# 1-Positivo 
# 2-Negativo 
# 3-Inconclusivo 
# 4-Não realizado 
# 9 - ignorado

influenza_old_4 <- influenza_old_4 %>%
  mutate(
    RES_FLUA = as.numeric(RES_FLUA),
    RES_FLUB = as.numeric(RES_FLUB)
  ) %>%
  mutate(
    influenza = case_when(
      RES_FLUA == 1 | RES_FLUB == 1 ~ 1,
      (RES_FLUA != 1 & RES_FLUB != 1) &
        (RES_FLUA == 2 | RES_FLUB == 2) ~ 0,
      TRUE ~ NA_real_
      # casos positivos nunca entram como 0
      # casos negativos precisam ter pelo menos um teste negativo
      # casos sem teste ficam NA
      # Isso evita viés de classificação.
    )
  )





unique(influenza_old_4$influenza)

