#===========  CRIA FUNCAO QUE IRA SER EXECUTADA EM TODA A LISTA DE DATAFRAME
processar_df <- function(INFLUENZA) {
  #=========== INICIA A ETAPA DE ATUALIZACAO DO DATAFRAME
  INFLUENZA <- INFLUENZA %>% 
    mutate(idade_anos = case_when(
      is.character(idade_anos) ~ as.integer(as.numeric(gsub(",", ".", idade_anos))),
      is.numeric(idade_anos) ~ as.integer(idade_anos),
      TRUE ~ NA_integer_
    )) %>% 
    #=========== FAZ O FILTRO PARA APENAS UTI, ADULTOS E COM EVOLUCAO CONHECIDA 
    filter(UTI == 1, idade_anos >= 18, EVOLUCAO %in% c(1,2,3)) %>% 
    #=========== SELECIONA APENAS AS COLUNAS DE INTERESSE CONFORME ESTUDO RANZANI
